page {
  background: #f6f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  box-sizing: border-box;
}

.section {
  margin-bottom: 24rpx;
}

.card {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  margin-bottom: 12rpx;
  color: #0f172a;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.6;
}

.metric-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.metric {
  flex: 1;
  padding: 20rpx;
  border-radius: 10rpx;
  background: #f8fafc;
}

.metric-value {
  display: block;
  color: #0f766e;
  font-size: 36rpx;
  font-weight: 700;
}

.metric-label {
  display: block;
  margin-top: 4rpx;
  color: #64748b;
  font-size: 24rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.primary-button,
.ghost-button {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 10rpx;
  font-size: 28rpx;
}

.primary-button {
  background: #0f766e;
  color: #ffffff;
}

.ghost-button {
  background: #e2e8f0;
  color: #0f172a;
}
