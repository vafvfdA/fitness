<view class="page">
  <view class="section">
    <view class="title">训练记录</view>
    <view class="subtitle">{{date}}</view>
  </view>

  <view class="section card">
    <view class="card-head">
      <view class="section-title">当天训练</view>
      <view class="status-text" wx:if="{{loading}}">加载中</view>
    </view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">{{summary.recordCount}}</text>
        <text class="metric-label">记录</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.totalSets}}</text>
        <text class="metric-label">组数</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.estimatedCalories}}</text>
        <text class="metric-label">消耗</text>
      </view>
    </view>
    <view class="button-row">
      <button class="primary-button" bindtap="createSampleTemplate" loading="{{saving}}" wx:if="{{templates.length === 0}}">创建示例模板</button>
      <button class="ghost-button" bindtap="goDiet">查看饮食</button>
    </view>
    <view class="error-text" wx:if="{{error}}">{{error}}</view>
  </view>

  <view class="section card">
    <view class="section-title">训练模板</view>
    <view class="empty-text" wx:if="{{templates.length === 0}}">暂无模板</view>
    <block wx:for="{{templates}}" wx:key="id">
      <view class="list-item">
        <view class="item-main">
          <view class="item-title">{{item.name}}</view>
          <view class="item-meta">{{item.bodyPart}} · {{item.items.length}} 个动作</view>
        </view>
        <button class="mini-button" data-id="{{item.id}}" bindtap="createWorkoutFromTemplate" loading="{{saving}}">生成</button>
      </view>
    </block>
  </view>

  <view class="section card">
    <view class="section-title">记录列表</view>
    <view class="empty-text" wx:if="{{records.length === 0}}">暂无训练记录</view>
    <block wx:for="{{records}}" wx:key="id">
      <view class="record-item">
        <view class="item-title">{{item.title || item.bodyPart}}</view>
        <view class="item-meta">{{item.bodyPart}} · {{item.totalSets}} 组 · {{item.estimatedCalories}} 千卡</view>
        <view class="exercise-line" wx:for="{{item.exercises}}" wx:for-item="exercise" wx:key="id">
          {{exercise.exerciseName}} · {{exercise.sets.length}} 组
        </view>
      </view>
    </block>
  </view>
</view>
