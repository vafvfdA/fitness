<view class="page">
  <view class="section">
    <view class="title">训练记录</view>
    <view class="subtitle">后续在这里录入动作、组数、重量和预估消耗热量。</view>
  </view>

  <view class="section card">
    <view class="subtitle">当前日期</view>
    <view class="title">{{date}}</view>
    <view class="button-row">
      <button class="primary-button">从模板添加</button>
      <button class="ghost-button" bindtap="goDiet">查看饮食</button>
    </view>
  </view>
</view>
