<view class="page">
  <view class="section">
    <view class="title">训练日历</view>
    <view class="subtitle">按月查看训练部位和热量消耗。</view>
  </view>

  <view class="section card">
    <view class="calendar-head">
      <button class="month-button" bindtap="previousMonth">上月</button>
      <view>
        <view class="section-title">{{monthTitle}}</view>
        <view class="status-text" wx:if="{{loading}}">加载中</view>
      </view>
      <button class="month-button" bindtap="nextMonth">下月</button>
    </view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">{{summary.trainingDays}}</text>
        <text class="metric-label">训练天数</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.estimatedCalories}}</text>
        <text class="metric-label">消耗千卡</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.totalSets}}</text>
        <text class="metric-label">总组数</text>
      </view>
    </view>
    <view class="error-text" wx:if="{{error}}">{{error}}</view>
  </view>

  <view class="section card calendar-card">
    <view class="week-row">
      <view class="week-cell" wx:for="{{weekdays}}" wx:key="*this">{{item}}</view>
    </view>
    <view class="day-grid">
      <view
        wx:for="{{days}}"
        wx:key="date"
        class="day-cell {{item.inMonth ? '' : 'muted-day'}} {{item.hasWorkout ? 'active-day' : ''}}"
        data-date="{{item.date}}"
        bindtap="openWorkout"
      >
        <view class="day-number">{{item.day}}</view>
        <view class="body-parts" wx:if="{{item.hasWorkout}}">{{item.bodyPartsText}}</view>
        <view class="calorie-text" wx:if="{{item.hasWorkout}}">{{item.estimatedCalories}} 千卡</view>
        <button
          class="diet-link"
          wx:if="{{item.inMonth}}"
          data-date="{{item.date}}"
          catchtap="openDiet"
        >饮食</button>
      </view>
    </view>
  </view>
</view>
