<view class="page">
  <view class="section">
    <view class="title">今日记录</view>
    <view class="subtitle">快速查看今天的训练、饮食和计划。</view>
  </view>

  <view class="section card">
    <view class="subtitle">训练摘要</view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">0</text>
        <text class="metric-label">动作</text>
      </view>
      <view class="metric">
        <text class="metric-value">0</text>
        <text class="metric-label">组数</text>
      </view>
      <view class="metric">
        <text class="metric-value">0</text>
        <text class="metric-label">千卡</text>
      </view>
    </view>
    <view class="button-row">
      <button class="primary-button" bindtap="goWorkout">记训练</button>
      <button class="ghost-button" bindtap="goDiet">记饮食</button>
    </view>
  </view>

  <view class="section card">
    <view class="subtitle">今日计划</view>
    <view class="title">暂未配置</view>
  </view>
</view>
