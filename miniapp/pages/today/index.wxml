<view class="page">
  <view class="section">
    <view class="title">今日记录</view>
    <view class="subtitle">{{date}}</view>
  </view>

  <view class="section card">
    <view class="card-head">
      <view>
        <view class="section-title">训练摘要</view>
        <view class="subtitle">{{summary.bodyPartsText}}</view>
      </view>
      <view class="status-text" wx:if="{{loading}}">加载中</view>
    </view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">{{summary.workoutCount}}</text>
        <text class="metric-label">记录</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.totalSets}}</text>
        <text class="metric-label">组数</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.workoutCalories}}</text>
        <text class="metric-label">消耗</text>
      </view>
    </view>
    <view class="button-row">
      <button class="primary-button" bindtap="goWorkout">记训练</button>
      <button class="ghost-button" bindtap="goDiet">记饮食</button>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">饮食摘要</view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">{{summary.dietCalories}}</text>
        <text class="metric-label">摄入</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.netCalories}}</text>
        <text class="metric-label">净热量</text>
      </view>
    </view>
    <view class="error-text" wx:if="{{error}}">{{error}}</view>
  </view>
</view>
