<view class="page">
  <view class="section">
    <view class="title">饮食记录</view>
    <view class="subtitle">{{date}}</view>
  </view>

  <view class="section card">
    <view class="card-head">
      <view class="section-title">当天饮食</view>
      <view class="status-text" wx:if="{{loading}}">加载中</view>
    </view>
    <view class="metric-row">
      <view class="metric">
        <text class="metric-value">{{summary.totalCalories}}</text>
        <text class="metric-label">摄入千卡</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{summary.foodCount}}</text>
        <text class="metric-label">食物</text>
      </view>
    </view>
    <view class="button-row">
      <button class="ghost-button" bindtap="goWorkout">查看训练</button>
    </view>
    <view class="error-text" wx:if="{{error}}">{{error}}</view>
  </view>

  <view class="section card">
    <view class="section-title">新增食物</view>
    <view class="template-entry">
      <button class="ghost-button" bindtap="openTemplatePicker">从模板选</button>
      <view class="status-text">模板里没有？可直接在下面手填</view>
    </view>
    <view class="form-grid">
      <input class="input" data-field="mealType" value="{{form.mealType}}" bindinput="onInput" placeholder="餐次" />
      <input class="input" data-field="foodName" value="{{form.foodName}}" bindinput="onInput" placeholder="食物名称" />
      <input class="input" data-field="amount" value="{{form.amount}}" bindinput="onInput" type="digit" placeholder="数量" />
      <input class="input" data-field="unit" value="{{form.unit}}" bindinput="onInput" placeholder="单位" />
      <input class="input" data-field="calories" value="{{form.calories}}" bindinput="onInput" type="digit" placeholder="热量" />
      <input class="input" data-field="proteinG" value="{{form.proteinG}}" bindinput="onInput" type="digit" placeholder="蛋白质" />
      <input class="input" data-field="fatG" value="{{form.fatG}}" bindinput="onInput" type="digit" placeholder="脂肪" />
      <input class="input" data-field="carbG" value="{{form.carbG}}" bindinput="onInput" type="digit" placeholder="碳水" />
    </view>
    <button class="primary-button full-button" bindtap="submitFood" loading="{{saving}}">添加食物</button>
  </view>

  <view class="section card">
    <view class="section-title">记录列表</view>
    <view class="empty-text" wx:if="{{records.length === 0}}">暂无饮食记录</view>
    <block wx:for="{{records}}" wx:key="id">
      <view class="record-item">
        <view class="item-title">{{item.totalCalories}} 千卡</view>
        <view class="item-meta">{{item.foods.length}} 个食物</view>
        <view class="food-line" wx:for="{{item.foods}}" wx:for-item="food" wx:key="id">
          {{food.mealType}} · {{food.foodName}} · {{food.amount}}{{food.unit}} · {{food.calories}} 千卡
        </view>
      </view>
    </block>
  </view>

  <!-- 模板选择器 -->
  <view wx:if="{{picker.visible}}" class="picker-mask">
    <view class="picker-panel">
      <view class="picker-head">
        <view class="section-title">选择食物模板</view>
        <view class="picker-close" bindtap="closeTemplatePicker">关闭</view>
      </view>
      <input class="input picker-search" value="{{picker.keyword}}" bindinput="onPickerKeywordInput" placeholder="搜索食物名称" />
      <view class="status-text" wx:if="{{picker.loading}}">加载中...</view>
      <view class="empty-text" wx:if="{{!picker.loading && picker.templates.length === 0}}">暂无模板</view>
      <scroll-view scroll-y class="picker-list">
        <view wx:for="{{picker.templates}}" wx:key="id" class="template-item" bindtap="pickTemplate" data-template="{{item}}">
          <view class="template-name">{{item.foodName}}</view>
          <view class="template-meta">{{item.caloriesPerUnit}} 千卡 / {{item.defaultUnit}}<text wx:if="{{item.mine}}" class="mine-tag">自建</text></view>
        </view>
      </scroll-view>
      <button class="primary-button full-button" bindtap="openAddTemplate">新增模板</button>
    </view>
  </view>

  <!-- 新增模板表单 -->
  <view wx:if="{{addForm.visible}}" class="picker-mask">
    <view class="picker-panel">
      <view class="picker-head">
        <view class="section-title">新增食物模板</view>
        <view class="picker-close" bindtap="closeAddTemplate">关闭</view>
      </view>
      <view class="form-grid">
        <input class="input" data-field="foodName" value="{{addForm.foodName}}" bindinput="onAddTemplateInput" placeholder="食物名称" />
        <input class="input" data-field="defaultUnit" value="{{addForm.defaultUnit}}" bindinput="onAddTemplateInput" placeholder="单位(如 100g/个)" />
        <input class="input" data-field="caloriesPerUnit" value="{{addForm.caloriesPerUnit}}" bindinput="onAddTemplateInput" type="digit" placeholder="每单位热量" />
        <input class="input" data-field="proteinPerUnit" value="{{addForm.proteinPerUnit}}" bindinput="onAddTemplateInput" type="digit" placeholder="每单位蛋白g" />
        <input class="input" data-field="fatPerUnit" value="{{addForm.fatPerUnit}}" bindinput="onAddTemplateInput" type="digit" placeholder="每单位脂肪g" />
        <input class="input" data-field="carbPerUnit" value="{{addForm.carbPerUnit}}" bindinput="onAddTemplateInput" type="digit" placeholder="每单位碳水g" />
      </view>
      <button class="primary-button full-button" bindtap="saveTemplate" loading="{{addForm.saving}}">保存模板</button>
    </view>
  </view>
</view>
