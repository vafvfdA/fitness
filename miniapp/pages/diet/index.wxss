.title {
  letter-spacing: 0;
}

.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 700;
}

.status-text,
.empty-text,
.item-meta,
.food-line {
  color: #64748b;
  font-size: 24rpx;
  line-height: 1.5;
}

.error-text {
  margin-top: 18rpx;
  color: #dc2626;
  font-size: 24rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 20rpx;
}

.input {
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #0f172a;
  font-size: 26rpx;
  box-sizing: border-box;
}

.full-button {
  width: 100%;
  margin-top: 22rpx;
}

.record-item {
  padding: 22rpx 0;
  border-top: 1rpx solid #e2e8f0;
}

.item-title {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}

/* 模板入口 */
.template-entry {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-top: 18rpx;
}

/* 模板选择器遮罩 */
.picker-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 100;
}

.picker-panel {
  width: 100%;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 28rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.picker-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.picker-close {
  color: #0f766e;
  font-size: 26rpx;
}

.picker-search {
  margin-bottom: 16rpx;
}

.picker-list {
  max-height: 50vh;
  margin-bottom: 18rpx;
}

.template-item {
  padding: 22rpx 18rpx;
  border-bottom: 1rpx solid #e2e8f0;
}

.template-name {
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 600;
}

.template-meta {
  color: #64748b;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.mine-tag {
  display: inline-block;
  margin-left: 12rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: #ccfbf1;
  color: #0f766e;
  font-size: 20rpx;
}
